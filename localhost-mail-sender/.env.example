PORT=4000

# Banco de dados (o MESMO banco usado pelo /backend - Supabase)
DB_HOST=aws-1-sa-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.xxxxxxxxxxxxxxxx
DB_PASS=sua_senha_do_banco

# SMTP (envio dos emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seuemail@exemplo.com
SMTP_PASS=sua_senha_de_app
MAIL_ADDRESS=seuemail@exemplo.com

# Keep-alive: URL base do backend no Render.
# O worker chama {KEEPALIVE_URL}/health a cada 15 minutos.
KEEPALIVE_URL=https://seu-app.onrender.com
